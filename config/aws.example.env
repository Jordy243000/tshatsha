# Configuration AWS S3
# Copiez ce fichier en .env et remplissez avec vos credentials AWS

# Région AWS (ex: us-east-1, eu-west-1, etc.)
AWS_REGION=us-east-1

# Access Key ID de votre utilisateur IAM AWS
AWS_ACCESS_KEY_ID=your_access_key_id_here

# Secret Access Key de votre utilisateur IAM AWS
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Nom du bucket S3 où stocker les fichiers
AWS_S3_BUCKET_NAME=your-bucket-name-here

